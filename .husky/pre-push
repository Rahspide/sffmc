#!/usr/bin/env sh
# SFFMC pre-push hook (managed by husky).
# Re-runs full precommit chain before pushing to remote.
# Bypass with: git push --no-verify
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "[pre-push] running bun run precommit ..."
bun run precommit

echo "[pre-push] ✓ all checks passed"
